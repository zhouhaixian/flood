{
  "name": "flood",
  "version": "1.6.25",
  "description": "短信之洪水",
  "main": "src/main.ts",
  "bin": "dist/main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "ts-node .",
    "debug": "ts-node ./scripts/debug",
    "new": "ts-node scripts/new",
    "delete": "ts-node scripts/delete",
    "build": "rimraf dist && tsc && pkg -C GZip ."
  },
  "pkg": {
    "scripts": [
      "dist/api/**/*.js",
      "node_modules/tesseract.js/src/worker-script/node/index.js"
    ],
    "assets": "configs/**/*",
    "targets": [
      "latest-win-x64"
    ],
    "outputPath": "dist/bin"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhouhaixian/flood.git"
  },
  "keywords": [
    "SMS"
  ],
  "author": "Zhou Haixian",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/zhouhaixian/flood/issues"
  },
  "homepage": "https://github.com/zhouhaixian/flood#readme",
  "devDependencies": {
    "@tsconfig/node18": "^1.0.1",
    "@types/node": "^18.11.0",
    "@types/node-rsa": "^1.1.1",
    "@types/sharp": "^0.31.0",
    "@types/tough-cookie": "^4.0.2",
    "@typescript-eslint/eslint-plugin": "^5.40.0",
    "@typescript-eslint/parser": "^5.40.0",
    "eslint": "^8.25.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^4.2.1",
    "pkg": "^5.8.0",
    "prettier": "^2.7.1",
    "rimraf": "^3.0.2",
    "ts-node": "^10.9.1",
    "tslib": "^2.4.0",
    "typescript": "^4.8.4"
  },
  "dependencies": {
    "got": "~11",
    "log4js": "^6.7.0",
    "node-rsa": "^1.1.1",
    "tesseract.js": "^3.0.3",
    "tough-cookie": "^4.1.2"
  }
}
